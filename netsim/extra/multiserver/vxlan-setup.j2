#!/bin/bash
# VXLAN tunnel setup — generated by netlab multiserver plugin
# Run AFTER:  sudo clab deploy -t clab.yml
#
# Creates host-level VXLAN tunnels and attaches them to containerlab bridges.
# These tunnels carry multi-access (bridged) cross-server traffic.
set -e

{% for t in tunnels %}
# VNI {{ t.vni }} -> {{ t.remote }} (server {{ t.remote_id }}) via bridge {{ t.bridge }}
# Remove any stale device first so a leftover tunnel can't abort the run.
ip link del vxlan{{ t.vni }} 2>/dev/null || true
ip link add vxlan{{ t.vni }} type vxlan id {{ t.vni }} remote {{ t.remote }} dev {{ dev }} dstport {{ t.dstport }}
ip link set vxlan{{ t.vni }} master {{ t.bridge }}
ip link set vxlan{{ t.vni }} up
echo "  vxlan{{ t.vni }} -> {{ t.bridge }} (remote {{ t.remote }})"

{% endfor %}
echo "VXLAN setup complete."
