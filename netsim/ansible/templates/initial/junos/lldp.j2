protocols {
  lldp {
    interface {{ mgmt.ifname|default('fxp0') }} {
      disable;
    }
    interface all;
  }
{% for l in netlab_interfaces if 'ipv6' in l and l.type != 'loopback' %}
{%   if loop.first %}
  router-advertisement {
{%   endif %}
    interface {{ l.ifname }};
{%   if loop.last %}
  }
{%   endif %}
{% endfor %}
}
